{
  "name": "licenseshield",
  "version": "0.1.0",
  "private": true,
  "description": "LicenseShield — production-grade SaaS license management platform for Chrome Extension licenses",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/web",
    "sdk"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck --workspace=apps/web",
    "sdk:build": "npm run build --workspace=sdk",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:types": "supabase gen types typescript --local > apps/web/src/lib/supabase/database.types.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "supabase": "^2.2.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2"
}
