# =============================================================================
# LicenseShield — Environment Variables
# Copy this file to `.env.local` (Next.js app) and `.env` (root) and fill in.
# NEVER commit real secrets. All NEXT_PUBLIC_* vars are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Razorpay (India payments — INR)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Platform crypto secrets
#  - PLATFORM_SECRET_KEY: HMAC secret used to sign/verify extension requests
#  - PLATFORM_RS256_*: RSA keypair used to sign offline license tokens (JWT RS256)
#    Generate with:
#      openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#      openssl rsa -pubout -in private.pem -out public.pem
#    Store PEM contents as a single line with literal \n, or base64-encode them.
# -----------------------------------------------------------------------------
PLATFORM_SECRET_KEY=
PLATFORM_RS256_PRIVATE_KEY=
PLATFORM_RS256_PUBLIC_KEY=
